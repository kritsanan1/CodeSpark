# Dyad AI App Builder - Environment Configuration
# Copy this file to .env and fill in your actual values

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# PostgreSQL database connection string
# Format: postgresql://username:password@host:port/database_name
# Example: postgresql://dyad_user:secure_password@localhost:5432/dyad_development
DATABASE_URL="postgresql://username:password@localhost:5432/dyad_db"

# =============================================================================
# SUPABASE CONFIGURATION
# =============================================================================

# Supabase project URL - Get this from your Supabase dashboard
# Format: https://your-project-id.supabase.co
VITE_SUPABASE_URL="https://your-project.supabase.co"

# Supabase anonymous key - Public key for client-side operations
# This key is safe to expose in client-side code
VITE_SUPABASE_ANON_KEY="your-supabase-anon-key"

# Supabase service role key - Server-side operations only
# ⚠️  KEEP THIS SECRET - Never expose in client-side code
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# =============================================================================
# AI SERVICE CONFIGURATION
# =============================================================================

# Google Gemini AI API Key
# Get your API key from: https://ai.google.dev/
# ⚠️  KEEP THIS SECRET - Required for AI code assistance features
GEMINI_API_KEY="your-gemini-api-key"

# AI Service Configuration
# Options: "gemini", "local", "mock"
AI_SERVICE_PROVIDER="gemini"

# Local AI Model Configuration (if using local AI)
# LOCAL_AI_MODEL_PATH="/path/to/your/local/model"
# LOCAL_AI_API_URL="http://localhost:8080"

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================

# Node.js environment
# Options: "development", "staging", "production"
NODE_ENV="development"

# Server port - Port for the Express.js backend server
# Default: 5000 (required for Replit deployment)
PORT="5000"

# Frontend development server port (Vite)
# Default: 5173
VITE_PORT="5173"

# API base URL for frontend requests
# Development: http://localhost:5000
# Production: https://your-domain.com
VITE_API_URL="http://localhost:5000"

# =============================================================================
# AUTHENTICATION CONFIGURATION
# =============================================================================

# JWT Secret for session management
# Generate a secure random string: openssl rand -base64 32
JWT_SECRET="your-jwt-secret-key-here"

# Session configuration
SESSION_SECRET="your-session-secret-key"
SESSION_MAX_AGE="86400000"  # 24 hours in milliseconds

# =============================================================================
# DEVELOPMENT CONFIGURATION
# =============================================================================

# Enable debug logging
DEBUG="dyad:*"

# Enable development features
ENABLE_DEV_TOOLS="true"

# Hot reload configuration
VITE_HMR_PORT="24678"

# =============================================================================
# REPLIT CONFIGURATION (if deploying on Replit)
# =============================================================================

# Replit-specific environment variables
# These are automatically set by Replit, but can be overridden
# REPL_ID="your-repl-id"
# REPL_SLUG="dyad-ai-app-builder"
# REPL_OWNER="your-username"

# =============================================================================
# MONITORING & ANALYTICS (Optional)
# =============================================================================

# Error tracking (e.g., Sentry)
# SENTRY_DSN="https://your-sentry-dsn@sentry.io/project-id"

# Analytics (e.g., Google Analytics)
# VITE_GA_TRACKING_ID="GA-XXXXXXXXX"

# Performance monitoring
# ENABLE_PERFORMANCE_MONITORING="false"

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================

# CORS configuration
# Comma-separated list of allowed origins
CORS_ORIGINS="http://localhost:5173,http://localhost:3000"

# Rate limiting
RATE_LIMIT_WINDOW_MS="900000"  # 15 minutes
RATE_LIMIT_MAX_REQUESTS="100"  # Max requests per window

# Content Security Policy
CSP_ENABLED="true"

# =============================================================================
# FILE STORAGE CONFIGURATION
# =============================================================================

# File upload limits
MAX_FILE_SIZE="10485760"  # 10MB in bytes
ALLOWED_FILE_TYPES="js,ts,jsx,tsx,css,html,json,md"

# Temporary file storage
TEMP_DIR="./tmp"

# =============================================================================
# CACHE CONFIGURATION
# =============================================================================

# Redis configuration (if using Redis for caching)
# REDIS_URL="redis://localhost:6379"
# REDIS_PASSWORD="your-redis-password"

# In-memory cache settings
CACHE_TTL="3600"  # 1 hour in seconds
MAX_CACHE_SIZE="100"  # Maximum number of cached items

# =============================================================================
# EMAIL CONFIGURATION (Optional)
# =============================================================================

# SMTP configuration for email notifications
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="587"
# SMTP_USER="your-email@gmail.com"
# SMTP_PASS="your-app-password"
# FROM_EMAIL="noreply@dyad.dev"

# =============================================================================
# FEATURE FLAGS
# =============================================================================

# Enable/disable specific features
ENABLE_AI_ASSISTANCE="true"
ENABLE_COMMUNITY_FEATURES="true"
ENABLE_DEBUGGING_TOOLS="true"
ENABLE_PERFORMANCE_MONITORING="true"
ENABLE_CODE_SNIPPETS="true"

# Beta features
ENABLE_ADVANCED_AI_FEATURES="false"
ENABLE_COLLABORATIVE_EDITING="false"

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================

# Log level: "error", "warn", "info", "debug"
LOG_LEVEL="info"

# Log format: "json", "simple"
LOG_FORMAT="simple"

# Enable file logging
LOG_TO_FILE="false"
LOG_FILE_PATH="./logs/dyad.log"

# =============================================================================
# DEVELOPMENT NOTES
# =============================================================================

# Environment Setup Instructions:
# 1. Copy this file to .env: cp .env.example .env
# 2. Fill in all required values (marked as required above)
# 3. For Supabase: Create project at https://supabase.com
# 4. For Gemini AI: Get API key at https://ai.google.dev/
# 5. Generate secure secrets using: openssl rand -base64 32
# 6. Never commit .env file to version control
# 7. Use different values for development/staging/production

# Security Reminders:
# - Keep all API keys and secrets secure
# - Use different keys for different environments
# - Regularly rotate sensitive credentials
# - Monitor API usage and set up alerts
# - Use environment-specific database instances

# Troubleshooting:
# - If database connection fails, check DATABASE_URL format
# - If AI features don't work, verify GEMINI_API_KEY is valid
# - If CORS errors occur, check CORS_ORIGINS includes your frontend URL
# - If build fails, ensure all VITE_ prefixed variables are set